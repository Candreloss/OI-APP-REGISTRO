<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro Participantes</title>

    <link rel="icon" type="image/png" href="/img/favicon.ico">
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@100;200;300;400;500;600;700;800;900&family=Geist:wght@100;200;300;400;500;600;700;800;900&family=IBM+Plex+Mono:wght@100;200;300;400;500;600;700&family=IBM+Plex+Sans:wght@100;200;300;400;500;600;700&family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Nunito:wght@200;300;400;500;600;700;800;900&family=PT+Serif:wght@400;700&family=Roboto+Slab:wght@100;200;300;400;500;600;700;800;900&family=Roboto:wght@100;300;400;500;700;900&family=Shantell+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>

    <link rel="stylesheet" href="/css/stylesprincipal.css" />
  </head>
  
  <body>
    <div class="export-wrapper">
      
      <nav class="top-bar">
        <div class="top-bar-left">
          <div class="logo-wrapper">
            <img src="/img/pic01.png" alt="Logo Organización Inteligente" class="nav-logo">
          </div>
        </div>

        <div style="width: 100%"></div>

        <div class="top-bar-right">
          <span class="admin-text">¿Eres admin?</span>
          <form action="/login" method="POST" style="margin: 0;">
            <button type="submit" class="btn-secondary" data-media-type="banani-button">
              <div class="icon-container">
                <iconify-icon icon="lucide:log-in" style="font-size: 16px; color: white"></iconify-icon>
              </div>
              Login
            </button>
          </form>
        </div>
      </nav>

      <div class="main-container" id="app-container">
        
        <section class="form-card" id="step-1-identity">
          <div class="form-header">
            <h2>Acceso Participantes</h2>
            <p class="form-subtitle">Ingresa tu cédula y correo para recibir un código de seguridad.</p>
          </div>

          <div class="form-grid" style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div class="form-group">
              <label class="label">Número de Documento (Cédula/Pasaporte)</label>
              <input type="text" id="auth-cedula" class="input" placeholder="Ej. 12345678" required />
            </div>

            <div class="form-group">
              <label class="label">Correo Electrónico</label>
              <input type="email" id="auth-email" class="input" placeholder="ejemplo@correo.com" required />
            </div>

            <button type="button" class="btn-primary" id="btn-solicitar" onclick="solicitarOTP()">
              Enviar Código de Acceso
            </button>
          </div>
        </section>

        <section class="form-card" id="step-2-otp" style="display: none;">
          <div class="form-header">
            <h2>Verifica tu Identidad</h2>
            <p class="form-subtitle" id="otp-subtitle">Hemos enviado un código a tu correo.</p>
          </div>

          <div class="form-grid" style="display: flex; flex-direction: column; gap: 1.25rem; align-items: center;">
            <div class="form-group" style="width: 100%; text-align: center;">
              <label class="label">Ingresa el código de 6 dígitos</label>
              <input type="text" id="auth-codigo" class="input" placeholder="000000" maxlength="6" style="text-align: center; font-size: 1.5rem; letter-spacing: 0.5rem; font-weight: bold; height: 60px;" required />
            </div>

            <button type="button" class="btn-primary" id="btn-validar" onclick="validarOTP()">
              Verificar y Continuar
            </button>
            
            <a href="#" onclick="volverPaso1()" style="font-size: 0.85rem; color: var(--brand-blue); text-decoration: none; margin-top: 10px;">← Usar otro correo</a>
          </div>
        </section>

        <section class="form-card" id="step-3-existente" style="display: none; width: 100%; max-width: 450px;">
          <div class="form-header">
            <h2 id="welcome-user-name" style="color: var(--brand-blue); font-size: 1.5rem; font-weight: 600;">¡Bienvenido!</h2>
            <p class="form-subtitle">¿Qué trámite deseas realizar hoy?</p>
          </div>

          <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem;">
            <button type="button" class="btn-primary" onclick="abrirNuevaInscripcion()">
              Inscribirme en una Capacitación Extra
            </button>
            <button type="button" class="btn-secondary" onclick="abrirReportePago()" style="justify-content: center; height: 44px; border: 1px solid var(--brand-blue); background: transparent; color: var(--brand-blue);">
              Reportar un Pago Pendiente
            </button>
          </div>
        </section>

        <section class="form-card" id="step-3-nuevo" style="display: none; width: 100%; max-width: 800px;">
          <div class="form-header">
            <h2>Completa tu Perfil</h2>
            <p class="form-subtitle">Como es tu primera vez, necesitamos tus datos básicos para emitir tus certificados.</p>
          </div>
          
          <form action="/registro" method="POST" style="margin-top: 1.5rem;">
            
            <input type="hidden" name="doc" id="hidden-doc" />
            <input type="hidden" name="email" id="hidden-email" />

            <div class="form-grid">
              
              <div class="form-group full-width">
                <label class="label">¿Qué tipo de documento ingresaste al inicio?</label>
                <div class="select-wrapper">
                  <select name="tipodoc" class="input" required>
                    <option value="" disabled selected>Selecciona una opción</option>
                    <option value="Ced">Cédula de Identidad</option>
                    <option value="Pas">Pasaporte</option>
                    <option value="Otr">Otro Documento</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="label">Nombre</label>
                <input name="nombre" type="text" class="input" placeholder="Tu nombre" required />
              </div>

              <div class="form-group">
                <label class="label">Apellido</label>
                <input name="apellido" type="text" class="input" placeholder="Tu apellido" required />
              </div>

              <div class="form-group">
                <label class="label">Código de país</label>
                <input name="codpais" type="text" class="input" placeholder="Ej. +58" maxlength="5" pattern="^\+\d{1,4}$" required />
              </div>
            
              <div class="form-group">
                  <label class="label">Número de teléfono</label>
                  <input name="telefono" type="tel" class="input" placeholder="Ej. 4123456789" minlength="7" maxlength="15" pattern="^\d{7,15}$" required />
              </div>

              <div class="form-group full-width"> 
                <label class="label">Fecha de Nacimiento</label>
                <div class="date-row">
                  <div class="date-col year-col">
                    <input name="año" type="number" class="input" placeholder="Año" min="1900" max="2030" required />
                    <span class="sub-label">Año</span>
                  </div>
                  <div class="date-col month-col">
                    <div class="select-wrapper">
                      <select name="mes" class="input" required style="appearance: none; cursor: pointer">
                          <option value="" disabled selected>Mes</option>
                          <option value="01">Ene</option><option value="02">Feb</option><option value="03">Mar</option>
                          <option value="04">Abr</option><option value="05">May</option><option value="06">Jun</option>
                          <option value="07">Jul</option><option value="08">Ago</option><option value="09">Sep</option>
                          <option value="10">Oct</option><option value="11">Nov</option><option value="12">Dic</option>
                      </select>
                    </div>
                    <span class="sub-label">Mes</span>
                  </div>
                  <div class="date-col day-col">
                    <input name="dia" type="number" class="input" placeholder="Día" min="1" max="31" required />
                    <span class="sub-label">Día</span>
                  </div>
                </div>
              </div>

              <div class="form-group">
                <label class="label">País de Residencia</label>
                <div class="select-wrapper">
                  <select name="pais" class="input" style="appearance: none; cursor: pointer" required>
                      <option value="" disabled selected>Selecciona tu país</option>
                      <option value="VE">Venezuela</option>
                      <optgroup label="Latinoamérica">
                        <option value="AR">Argentina</option><option value="CO">Colombia</option><option value="CL">Chile</option>
                        <option value="MX">México</option><option value="PE">Perú</option><option value="EC">Ecuador</option>
                      </optgroup>
                      <option value="OT">Otro</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="label">Ciudad</label>
                <input name="ciudad" type="text" class="input" placeholder="Ciudad actual" required />
              </div>
            </div>

            <div style="margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid var(--border);">
              <h3 style="color: var(--brand-blue); font-size: 1.2rem; font-weight: 600; margin-bottom: 1rem;">
                ¿En qué capacitación deseas inscribirte hoy?
              </h3>
              
              <div class="offers-grid">
                <% if (ofertas && ofertas.length > 0) { %>
                    <% ofertas.forEach((oferta) => { %>
                        <label class="offer-card">
                            <input type="radio" name="capacitacion" value="<%= oferta.capofcodigo %>" required>
                            <div class="offer-details">
                                <span class="offer-title"><%= oferta.capnombre %></span>
                                <span class="offer-code">Código: <%= oferta.capofcodigo %></span>
                            </div>
                        </label>
                    <% }); %>
                <% } else { %>
                    <p class="placeholder-text" style="color: var(--text-muted);">No hay capacitaciones activas.</p>
                <% } %>
              </div>
            </div>

            <div class="full-width" style="margin-top: 2rem;">
              <button type="submit" class="btn-primary">
                Guardar Perfil e Inscribirme
              </button>
            </div>
          </form>
        </section>

      </div>
    </div>
    <script>
      // Variables globales para guardar la memoria del usuario
      let correoActual = '';
      let cedulaActual = '';
      let esUsuarioNuevo = true;
      let nombreActual = ''; // Agregamos la variable para el nombre

      // DOM Elements
      const step1 = document.getElementById('step-1-identity');
      const step2 = document.getElementById('step-2-otp');
      const step3Existente = document.getElementById('step-3-existente');
      const step3Nuevo = document.getElementById('step-3-nuevo');
      const btnSolicitar = document.getElementById('btn-solicitar');
      const btnValidar = document.getElementById('btn-validar');

      async function solicitarOTP() {
          const cedula = document.getElementById('auth-cedula').value.trim();
          const email = document.getElementById('auth-email').value.trim();

          if(!cedula || !email) {
              alert("Por favor, llena ambos campos.");
              return;
          }

          btnSolicitar.innerText = "Enviando correo...";
          btnSolicitar.disabled = true;

          try {
              const response = await fetch('/api/solicitar-otp', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ cedula, email })
              });

              const data = await response.json();

              if(data.success) {
                  correoActual = email;
                  cedulaActual = cedula;
                  esUsuarioNuevo = data.esNuevo;
                  nombreActual = data.nombre; // Guardamos el nombre que responde la BD
                  
                  document.getElementById('otp-subtitle').innerText = `Hemos enviado un código a ${email}`;
                  step1.style.display = 'none';
                  step2.style.display = 'block';
              } else {
                  alert("Error: " + data.message);
              }
          } catch (error) {
              alert("Error de conexión con el servidor.");
          } finally {
              btnSolicitar.innerText = "Enviar Código de Acceso";
              btnSolicitar.disabled = false;
          }
      }

      async function validarOTP() {
          const codigo = document.getElementById('auth-codigo').value.trim();

          if(codigo.length !== 6) {
              alert("El código debe tener 6 dígitos.");
              return;
          }

          btnValidar.innerText = "Verificando...";
          btnValidar.disabled = true;

          try {
              const response = await fetch('/api/validar-otp', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ email: correoActual, codigo })
              });

              const data = await response.json();

              if(data.success) {
                  step2.style.display = 'none';
                  
                  // --- LA BIFURCACIÓN MÁGICA ---
                  if(esUsuarioNuevo) {
                      // NUEVO: Llenamos los inputs ocultos
                      document.getElementById('hidden-doc').value = cedulaActual;
                      document.getElementById('hidden-email').value = correoActual;

                      step3Nuevo.style.display = 'block';
                  } else {
                      document.getElementById('welcome-user-name').innerText = '¡Hola, ' + nombreActual + '!';
                      step3Existente.style.display = 'block';
                  }
              } else {
                  alert(data.message);
              }
          } catch (error) {
              alert("Error de conexión con el servidor.");
          } finally {
              btnValidar.innerText = "Verificar y Continuar";
              btnValidar.disabled = false;
          }
      }

      function volverPaso1() {
          step2.style.display = 'none';
          step1.style.display = 'block';
          document.getElementById('auth-codigo').value = '';
      }

      // Funciones temporales para los botones del panel existente
      function abrirNuevaInscripcion() { alert("Próximamente: Mostraremos la lista de cursos disponibles."); }
      function abrirReportePago() { alert("Próximamente: Mostraremos tus pagos pendientes."); }
    </script>
  </body>
</html>