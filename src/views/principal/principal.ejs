<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro Participantes</title>

    <link rel="icon" type="image/png" href="/img/favicon.ico">
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@100;200;300;400;500;600;700;800;900&family=Geist:wght@100;200;300;400;500;600;700;800;900&family=IBM+Plex+Mono:wght@100;200;300;400;500;600;700&family=IBM+Plex+Sans:wght@100;200;300;400;500;600;700&family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Nunito:wght@200;300;400;500;600;700;800;900&family=PT+Serif:wght@400;700&family=Roboto+Slab:wght@100;200;300;400;500;600;700;800;900&family=Roboto:wght@100;300;400;500;700;900&family=Shantell+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>

    <link rel="stylesheet" href="/css/stylesprincipal.css" />
  </head>
  
  <body>
    <div class="export-wrapper">
      
      <nav class="top-bar">
        <div class="top-bar-left">
          <div class="logo-wrapper">
            <img src="/img/pic01.png" alt="Logo Organización Inteligente" class="nav-logo">
          </div>
        </div>

        <div style="width: 100%"></div>

        <div class="top-bar-right">
          <span class="admin-text">¿Eres admin?</span>
          <form action="/login" method="POST" style="margin: 0;">
            <button type="submit" class="btn-secondary" data-media-type="banani-button">
              <div class="icon-container">
                <iconify-icon icon="lucide:log-in" style="font-size: 16px; color: white"></iconify-icon>
              </div>
              Login
            </button>
          </form>
          <a href="/empresas" style="font-size: 0.85rem; font-weight: 600; color: #10b981; text-decoration: none; margin-right: 15px;">
              Módulo Empresas
          </a>
        </div>
      </nav>

      <div class="main-container" id="app-container">
        
        <section class="form-card" id="step-1-identity">
          <div class="form-header">
            <h2>Acceso Participantes</h2>
            <p class="form-subtitle">Ingresa tu cédula y correo para recibir un código de seguridad.</p>
          </div>

          <div class="form-grid" style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div class="form-group">
              <label class="label">Número de Documento (Cédula/Pasaporte)</label>
              <input type="text" id="auth-cedula" class="input" placeholder="Ej. 12345678" required />
            </div>

            <div class="form-group">
              <label class="label">Correo Electrónico</label>
              <input type="email" id="auth-email" class="input" placeholder="ejemplo@correo.com" required />
            </div>

            <button type="button" class="btn-primary" id="btn-solicitar" onclick="solicitarOTP()">
              Enviar Código de Acceso
            </button>
          </div>
        </section>

        <section class="form-card" id="step-2-otp" style="display: none;">
          <div class="form-header">
            <h2>Verifica tu Identidad</h2>
            <p class="form-subtitle" id="otp-subtitle">Hemos enviado un código a tu correo.</p>
          </div>

          <div class="form-grid" style="display: flex; flex-direction: column; gap: 1.25rem; align-items: center;">
            <div class="form-group" style="width: 100%; text-align: center;">
              <label class="label">Ingresa el código de 6 dígitos</label>
              <input type="text" id="auth-codigo" class="input" placeholder="000000" maxlength="6" style="text-align: center; font-size: 1.5rem; letter-spacing: 0.5rem; font-weight: bold; height: 60px;" required />
            </div>

            <button type="button" class="btn-primary" id="btn-validar" onclick="validarOTP()">
              Verificar y Continuar
            </button>
            
            <a href="#" onclick="volverPaso1()" style="font-size: 0.85rem; color: var(--brand-blue); text-decoration: none; margin-top: 10px;">← Usar otro correo</a>
          </div>
        </section>

        <section class="form-card" id="step-3-existente" style="display: none; width: 100%; max-width: 450px;">
          <div class="form-header">
            <h2 id="welcome-user-name" style="color: var(--brand-blue); font-size: 1.5rem; font-weight: 600;">¡Bienvenido!</h2>
            <p class="form-subtitle">¿Qué trámite deseas realizar hoy?</p>
          </div>

          <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem;">
            <button type="button" class="btn-primary" onclick="abrirNuevaInscripcion()">
              Inscribirme en una Capacitación Extra
            </button>
            <button type="button" class="btn-secondary" onclick="abrirReportePago()" style="justify-content: center; height: 44px; border: 1px solid var(--brand-blue); background: transparent; color: var(--brand-blue);">
              Reportar un Pago Pendiente
            </button>
          </div>
        </section>

        <section class="form-card" id="step-3-pago" style="display: none; width: 100%; max-width: 600px;">
          <div class="form-header">
            <h2>Reportar Pago</h2>
            <p class="form-subtitle">Ingresa los datos exactos de la cuenta bancaria desde donde se realizó el pago.</p>
          </div>

          <form onsubmit="procesarReportePago(event)" id="form-pago" enctype="multipart/form-data" style="margin-top: 1.5rem;">
            <input type="hidden" name="doc_pago" id="hidden-doc-pago" />

            <div class="form-group" style="margin-bottom: 1.5rem;">
              <label class="label" style="color: var(--brand-blue); font-weight: 700;">1. ¿Qué capacitación estás pagando?</label>
              <div class="select-wrapper">
                <select name="curso_pagado" id="select-cursos-pendientes" class="input" required>
                  <option value="" disabled selected>Cargando tus cursos pendientes...</option>
                </select>
              </div>
            </div>

            <label class="label" style="color: var(--brand-blue); font-weight: 700; margin-bottom: 1rem; display: block;">2. Datos del Titular de la Cuenta</label>
            
            <div class="form-grid">
              <div class="form-group">
                <label class="label">Nombre del Titular</label>
                <input name="titular_nombre" type="text" class="input" placeholder="Ej. Maria" required />
              </div>

              <div class="form-group">
                <label class="label">Apellido del Titular</label>
                <input name="titular_apellido" type="text" class="input" placeholder="Ej. Mendoza" required />
              </div>

              <div class="form-group">
                <label class="label">Banco de Origen</label>
                <input name="banco_origen" type="text" class="input" placeholder="Ej. Banesco, Mercantil..." required />
              </div>

              <div class="form-group">
                <label class="label">Número de Referencia</label>
                <input name="referencia" type="text" class="input" placeholder="Últimos 6 dígitos" required />
              </div>

              <div class="form-group full-width">
                <label class="label">Teléfono asociado al pago (Pago Móvil / Zelle)</label>
                <input name="titular_telefono" type="text" class="input" placeholder="Ej. 04141234567" required />
              </div>

              <div class="form-group full-width" style="margin-top: 1rem; border: 2px dashed var(--border); padding: 1.5rem; border-radius: var(--radius); text-align: center; background-color: var(--background);">
                <label class="label" style="margin-bottom: 10px; color: var(--brand-blue); font-weight: 600;">
                    <iconify-icon icon="lucide:image" style="font-size: 24px; vertical-align: middle; margin-right: 8px;"></iconify-icon>
                    Adjuntar Capture de Pago (Obligatorio)
                </label>
                <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1rem;">Formatos aceptados: JPG, JPEG, PNG. Tamaño máximo: 5MB.</p>
                <input type="file" name="comprobante" class="input" accept="image/png, image/jpeg, image/jpg" style="padding: 6px; height: auto; cursor: pointer;" required />
              </div>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
              <button type="button" class="btn-secondary" onclick="volverPanelExistente()" style="width: 100%; justify-content: center; background: transparent; border: 1px solid var(--border); color: var(--text-main);">
                Cancelar
              </button>
              <button type="submit" class="btn-primary" style="margin-top: 0;">
                Enviar Reporte
              </button>
            </div>
          </form>
        </section>

        <section class="form-card" id="step-3-nueva-inscripcion" style="display: none; width: 100%; max-width: 500px;">
          <div class="form-header">
            <h2>Nueva Inscripción</h2>
            <p class="form-subtitle">Selecciona la capacitación a la que deseas unirte.</p>
          </div>
          
          <form onsubmit="procesarInscripcionRapida(event)" style="margin-top: 1.5rem;">
            <div class="form-group" style="margin-bottom: 1.5rem;">
              <label class="label" style="color: var(--brand-blue); font-weight: 700;">Capacitaciones Disponibles para ti:</label>
              <div class="select-wrapper">
                <select id="select-nuevas-ofertas" class="input" required>
                  <option value="" disabled selected>Buscando capacitaciones...</option>
                </select>
              </div>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
              <button type="button" class="btn-secondary" onclick="volverDesdeNuevaInscripcion()" style="width: 100%; justify-content: center; background: transparent; border: 1px solid var(--border); color: var(--text-main);">
                Cancelar
              </button>
              <button type="submit" class="btn-primary" style="margin-top: 0; width: 100%;">
                Inscribirme Ahora
              </button>
            </div>
          </form>
        </section>

        <section class="form-card" id="step-3-nuevo" style="display: none; width: 100%; max-width: 800px;">
          <div class="form-header">
            <h2>Completa tu Perfil</h2>
            <p class="form-subtitle">Como es tu primera vez, necesitamos tus datos básicos para emitir tus certificados.</p>
          </div>
          
          <form onsubmit="procesarRegistroCompleto(event)" id="form-registro" style="margin-top: 1.5rem;">
            <input type="hidden" name="doc" id="hidden-doc" />
            <input type="hidden" name="email" id="hidden-email" />

            <div class="form-grid">
              <div class="form-group full-width">
                <label class="label">¿Qué tipo de documento ingresaste al inicio?</label>
                <div class="select-wrapper">
                  <select name="tipodoc" class="input" required>
                    <option value="" disabled selected>Selecciona una opción</option>
                    <option value="Ced">Cédula de Identidad</option>
                    <option value="Pas">Pasaporte</option>
                    <option value="Otr">Otro Documento</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="label">Nombre</label>
                <input name="nombre" type="text" class="input" placeholder="Tu nombre" required />
              </div>

              <div class="form-group">
                <label class="label">Apellido</label>
                <input name="apellido" type="text" class="input" placeholder="Tu apellido" required />
              </div>

              <div class="form-group">
                  <label class="label">Código de país</label>
                  <div class="select-wrapper">
                      <select name="codpais" class="input" required>
                          <option value="" disabled selected>Selecciona</option>
                          <option value="+58">+58 (VE)</option>
                          <option value="+57">+57 (CO)</option>
                          <option value="+54">+54 (AR)</option>
                          <option value="+56">+56 (CL)</option>
                          <option value="+51">+51 (PE)</option>
                          <option value="+593">+593 (EC)</option>
                          <option value="+52">+52 (MX)</option>
                          <option value="+55">+55 (BR)</option>
                          <option value="+598">+598 (UY)</option>
                          <option value="+595">+595 (PY)</option>
                          <option value="+591">+591 (BO)</option>
                          <option value="+1">+1 (US/CA)</option>
                          <option value="+34">+34 (ES)</option>
                      </select>
                  </div>
              </div>

              <div class="form-group">
                  <label class="label">Número de teléfono</label>
                  <input name="telefono" type="tel" class="input" placeholder="Ej. 4123456789" 
                        minlength="7" maxlength="15" 
                        oninput="this.value = this.value.replace(/^0+/, '')" required />
              </div>

              <div class="form-group" style="grid-column: span 2;">
                  <label class="label">Fecha de Nacimiento</label>
                  <input type="date" name="fechanac" class="input" required />
              </div>

              <div class="form-group">
                <label class="label">País de Residencia</label>
                <div class="select-wrapper">
                  <select name="pais" class="input" style="appearance: none; cursor: pointer" required>
                      <option value="" disabled selected>Selecciona tu país</option>
                      <option value="VE">Venezuela</option>
                      <optgroup label="Latinoamérica">
                        <option value="AR">Argentina</option><option value="CO">Colombia</option><option value="CL">Chile</option>
                        <option value="MX">México</option><option value="PE">Perú</option><option value="EC">Ecuador</option>
                      </optgroup>
                      <option value="OT">Otro</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="label">Ciudad</label>
                <input name="ciudad" type="text" class="input" placeholder="Ciudad actual" required />
              </div>
            </div>

            <div style="margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid var(--border);">
              <h3 style="color: var(--brand-blue); font-size: 1.2rem; font-weight: 600; margin-bottom: 1rem;">
                ¿En qué capacitación deseas inscribirte hoy?
              </h3>
              
              <div class="offers-grid">
                <% if (ofertas && ofertas.length > 0) { %>
                    <% ofertas.forEach((oferta) => { %>
                        <% 
                            const agotado = oferta.cupos_restantes <= 0; 
                            const bloqueado = oferta.cupos_bloqueados === 1;
                            const isDisabled = agotado || bloqueado ? 'disabled' : '';
                        %>
                        <label class="offer-card <%= isDisabled ? 'opacity-50 cursor-not-allowed bg-gray-50' : '' %>">
                            <input type="radio" name="capacitacion" value="<%= oferta.capofcodigo %>" <%= isDisabled %> required>
                            <div class="offer-details">
                                <span class="offer-title">
                                    <%= oferta.capnombre %>
                                    <% if(bloqueado) { %> 
                                        <span style="color: #ef4444; font-size: 0.8rem; font-weight: bold;">(CERRADO)</span> 
                                    <% } else if(agotado) { %> 
                                        <span style="color: #ef4444; font-size: 0.8rem; font-weight: bold;">(AGOTADO)</span> 
                                    <% } %>
                                </span>
                                <span class="offer-code">Cupos Disponibles: <%= Math.max(0, oferta.cupos_restantes) %></span>
                            </div>
                        </label>
                    <% }); %>
                <% } else { %>
                    <p class="placeholder-text" style="color: var(--text-muted);">No hay capacitaciones activas.</p>
                <% } %>
              </div>
            </div>

            <div class="full-width" style="margin-top: 2rem;">
              <button type="submit" class="btn-primary">
                Guardar Perfil e Inscribirme
              </button>
            </div>
          </form>
        </section>

      </div>
    </div>

    <script>
      let correoActual = '';
      let cedulaActual = '';
      let esUsuarioNuevo = true;
      let nombreActual = '';

      const step1 = document.getElementById('step-1-identity');
      const step2 = document.getElementById('step-2-otp');
      const step3Existente = document.getElementById('step-3-existente');
      const step3Pago = document.getElementById('step-3-pago');
      const step3NuevaInsc = document.getElementById('step-3-nueva-inscripcion');
      const step3Nuevo = document.getElementById('step-3-nuevo');
      
      const btnSolicitar = document.getElementById('btn-solicitar');
      const btnValidar = document.getElementById('btn-validar');

      async function solicitarOTP() {
          const cedula = document.getElementById('auth-cedula').value.trim();
          const email = document.getElementById('auth-email').value.trim();

          if(!cedula || !email) {
              alert("Por favor, llena ambos campos.");
              return;
          }

          btnSolicitar.innerText = "Enviando correo...";
          btnSolicitar.disabled = true;

          try {
              const response = await fetch('/api/solicitar-otp', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ cedula, email })
              });

              const data = await response.json();

              if(data.success) {
                  correoActual = email;
                  cedulaActual = cedula;
                  esUsuarioNuevo = data.esNuevo;
                  nombreActual = data.nombre;
                  
                  document.getElementById('otp-subtitle').innerText = `Hemos enviado un código a ${email}`;
                  step1.style.display = 'none';
                  step2.style.display = 'block';
              } else {
                  alert("Error: " + data.message);
              }
          } catch (error) {
              alert("Error de conexión con el servidor.");
          } finally {
              btnSolicitar.innerText = "Enviar Código de Acceso";
              btnSolicitar.disabled = false;
          }
      }

      async function validarOTP() {
          const codigo = document.getElementById('auth-codigo').value.trim();

          if(codigo.length !== 6) {
              alert("El código debe tener 6 dígitos.");
              return;
          }

          btnValidar.innerText = "Verificando...";
          btnValidar.disabled = true;

          try {
              const response = await fetch('/api/validar-otp', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ email: correoActual, codigo })
              });

              const data = await response.json();

              if(data.success) {
                  step2.style.display = 'none';
                  
                  if(esUsuarioNuevo) {
                      document.getElementById('hidden-doc').value = cedulaActual;
                      document.getElementById('hidden-email').value = correoActual;
                      step3Nuevo.style.display = 'block';
                  } else {
                      document.getElementById('welcome-user-name').innerText = '¡Hola, ' + nombreActual + '!';
                      step3Existente.style.display = 'block';
                  }
              } else {
                  alert(data.message);
              }
          } catch (error) {
              alert("Error de conexión con el servidor.");
          } finally {
              btnValidar.innerText = "Verificar y Continuar";
              btnValidar.disabled = false;
          }
      }

      function volverPaso1() {
          step2.style.display = 'none';
          step1.style.display = 'block';
          document.getElementById('auth-codigo').value = '';
      }

      // --- FUNCIONES DEL PANEL EXISTENTE ---
      async function abrirNuevaInscripcion() { 
          step3Existente.style.display = 'none';
          step3NuevaInsc.style.display = 'block';

          const selectOfertas = document.getElementById('select-nuevas-ofertas');
          selectOfertas.innerHTML = '<option value="" disabled selected>Buscando capacitaciones...</option>';

          try {
              const response = await fetch(`/api/ofertas-disponibles/${cedulaActual}`);
              const ofertas = await response.json();

              if(ofertas.length > 0) {
                  selectOfertas.innerHTML = '<option value="" disabled selected>Selecciona una capacitación</option>';
                  ofertas.forEach(o => {
                      selectOfertas.innerHTML += `<option value="${o.capofcodigo}">${o.capnombre} (Código: ${o.capofcodigo})</option>`;
                  });
              } else {
                  selectOfertas.innerHTML = '<option value="" disabled selected>Ya estás inscrito en todos los cursos activos</option>';
              }
          } catch (error) {
              selectOfertas.innerHTML = '<option value="" disabled selected>Error al cargar capacitaciones</option>';
          }
      }

      function volverDesdeNuevaInscripcion() {
          step3NuevaInsc.style.display = 'none';
          step3Existente.style.display = 'block';
      }

      async function procesarInscripcionRapida(event) {
          event.preventDefault(); 
          const form = event.target; // Capturamos el formulario
          const btn = form.querySelector('button[type="submit"]'); // Capturamos el botón
          const capacitacion = document.getElementById('select-nuevas-ofertas').value;
          
          if(!capacitacion) {
              alert("Por favor selecciona una capacitación.");
              return;
          }

          // EL CANDADO: Bloqueamos el botón para evitar dobles clics
          btn.innerText = "Procesando...";
          btn.disabled = true;

          try {
              const response = await fetch('/api/inscripcion-rapida', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ cedula: cedulaActual, capacitacion: capacitacion })
              });

              const data = await response.json();

              if(data.success) {
                  alert(data.message);
                  volverDesdeNuevaInscripcion();
              } else {
                  alert("Error: " + data.message);
              }
          } catch (error) {
              alert("Error de conexión con el servidor.");
          } finally {
              // QUITAMOS EL CANDADO si falla o termina
              btn.innerText = "Inscribirme Ahora";
              btn.disabled = false;
          }
      }

      async function abrirReportePago() { 
          step3Existente.style.display = 'none';
          step3Pago.style.display = 'block';
          document.getElementById('hidden-doc-pago').value = cedulaActual;

          const selectCursos = document.getElementById('select-cursos-pendientes');
          selectCursos.innerHTML = '<option value="" disabled selected>Buscando tus inscripciones pendientes...</option>';

          try {
              const response = await fetch(`/api/cursos-pendientes/${cedulaActual}`);
              const cursos = await response.json();

              if(cursos.length > 0) {
                  selectCursos.innerHTML = '<option value="" disabled selected>Selecciona un curso</option>';
                  cursos.forEach(c => {
                      selectCursos.innerHTML += `<option value="${c.inscodigo}">${c.capnombre} (Inscripción #${c.inscodigo})</option>`;
                  });
              } else {
                  selectCursos.innerHTML = '<option value="" disabled selected>No tienes pagos pendientes registrados</option>';
              }
          } catch (error) {
              selectCursos.innerHTML = '<option value="" disabled selected>Error al cargar cursos</option>';
          }
      }

      function volverPanelExistente() {
          step3Pago.style.display = 'none';
          step3Existente.style.display = 'block';
      }

      // --- NUEVAS FUNCIONES PARA PROCESAR LOS FORMULARIOS CON JSON Y FETCH ---
      
      async function procesarRegistroCompleto(event) {
          event.preventDefault();
          const form = document.getElementById('form-registro');
          const formData = new FormData(form);
          const data = Object.fromEntries(formData.entries());
          const btn = form.querySelector('button[type="submit"]');

          btn.innerText = "Procesando Inscripción...";
          btn.disabled = true;

          try {
              const response = await fetch('/registro', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(data)
              });
              const result = await response.json();

              if (result.success) {
                  alert(result.message);
                  window.location.href = "/";
              } else {
                  alert("Error: " + result.message);
              }
          } catch (error) {
              alert("Error conectando con el servidor.");
          } finally {
              btn.innerText = "Guardar Perfil e Inscribirme";
              btn.disabled = false;
          }
      }

      async function procesarReportePago(event) {
          event.preventDefault();
          const form = document.getElementById('form-pago');
          const formData = new FormData(form);
          const btn = form.querySelector('button[type="submit"]');

          btn.innerText = "Subiendo Comprobante...";
          btn.disabled = true;

          try {
              // A diferencia del registro, el pago envía un archivo, por lo que mandamos el FormData crudo sin JSON
              const response = await fetch('/api/reportar-pago', {
                  method: 'POST',
                  body: formData
              });
              const result = await response.json();

              if (result.success) {
                  alert(result.message);
                  window.location.href = "/";
              } else {
                  alert("Error: " + result.message);
              }
          } catch (error) {
              alert("Error conectando con el servidor.");
          } finally {
              btn.innerText = "Enviar Reporte";
              btn.disabled = false;
          }
      }
    </script>
  </body>
</html>