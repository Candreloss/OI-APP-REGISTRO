<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Participantes y Pagos | Organización Inteligente</title>
    <link rel="icon" type="image/png" href="/img/favicon.ico">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/adminpanel.css">
</head>
<body>
    <div class="dashboard-container">
        
        <aside class="sidebar">
            <div class="sidebar-header">
                <img src="/img/pic01.png" alt="Logo OI" class="sidebar-logo">
            </div>
            <nav class="sidebar-nav">
                <a href="/panel" class="nav-item">
                    <iconify-icon icon="lucide:layout-dashboard"></iconify-icon>
                    <span>Dashboard</span>
                </a>
                <a href="/panel/ofertas" class="nav-item">
                    <iconify-icon icon="lucide:book-open"></iconify-icon>
                    <span>Ofertas de Capacitación</span>
                </a>
                <a href="/panel/participantes" class="nav-item active">
                    <iconify-icon icon="lucide:users"></iconify-icon>
                    <span>Participantes y Pagos</span>
                </a>
            </nav>
            <div class="sidebar-footer">
                <a href="/logout" class="nav-item logout-btn">
                    <iconify-icon icon="lucide:log-out"></iconify-icon>
                    <span>Cerrar Sesión</span>
                </a>
            </div>
        </aside>

        <main class="main-content">
            <header class="top-header">
                <div class="header-title">
                    <h1>Módulo de Conciliación</h1>
                </div>
                <div class="header-user">
                    <iconify-icon icon="lucide:user-circle" class="user-icon"></iconify-icon>
                    <span class="user-name">Hola, Admin</span>
                </div>
            </header>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mt-8">
              <div class="flex justify-between items-center mb-6">
                <div>
                  <h2 class="text-2xl font-bold text-gray-800">Gestión de Participantes</h2>
                  <p class="text-gray-500 text-sm">Administra inscripciones, edita perfiles y concilia pagos reportados.</p>
                </div>
              </div>

              <div class="flex gap-3 mb-6 overflow-x-auto pb-2">
                <button class="px-4 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white shadow-sm" onclick="filtrarTabla('todas')">
                  Todas
                </button>
                <button class="px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200" onclick="filtrarTabla('pendiente')">
                  🟡 Pendientes
                </button>
                <button class="px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200" onclick="filtrarTabla('en_revision')">
                  🟠 En Revisión
                </button>
                <button class="px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200" onclick="filtrarTabla('conciliado')">
                  🟢 Conciliados
                </button>
              </div>

              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="bg-gray-50 text-gray-600 text-sm border-b border-gray-200">
                      <th class="p-4 font-semibold">Documento</th>
                      <th class="p-4 font-semibold">Participante</th>
                      <th class="p-4 font-semibold">Capacitación</th>
                      <th class="p-4 font-semibold">Estado</th>
                      <th class="p-4 font-semibold text-center">Acciones</th>
                    </tr>
                  </thead>
                  <tbody id="tabla-inscripciones" class="text-sm text-gray-700 divide-y divide-gray-100">
                    
                    <% if (inscripciones && inscripciones.length > 0) { %>
                        <% inscripciones.forEach((ins) => { %>
                            
                            <tr class="hover:bg-gray-50 transition-colors fila-inscripcion" data-estado="<%= ins.ins_estado %>">
                              <td class="p-4 font-mono"><%= ins.perdoc %></td>
                              <td class="p-4">
                                <div class="font-medium text-gray-900"><%= ins.pernombre %> <%= ins.perapellido %></div>
                                <div class="text-xs text-gray-500"><%= ins.pertelefono %></div>
                              </td>
                              <td class="p-4"><%= ins.capnombre %></td>
                              <td class="p-4">
                                <% if(ins.ins_estado === 'pendiente') { %>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Pendiente</span>
                                <% } else if(ins.ins_estado === 'en_revision') { %>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800">En Revisión</span>
                                <% } else if(ins.ins_estado === 'conciliado') { %>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Conciliado</span>
                                <% } else { %>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Rechazado</span>
                                <% } %>
                              </td>
                              <td class="p-4 flex justify-center gap-2">
                                <button onclick="abrirModalEdicion('<%= ins.perdoc %>', '<%= ins.pernombre %>', '<%= ins.perapellido %>', '<%= ins.pertelefono %>')" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg" title="Editar Perfil">
                                  <iconify-icon icon="lucide:edit" class="text-lg"></iconify-icon>
                                </button>
                                
                                <% if(ins.ins_estado === 'en_revision') { %>
                                    <button onclick="abrirModalPago('<%= ins.inscodigo %>', '<%= ins.titular_nombre %> <%= ins.titular_apellido %>', '<%= ins.banco_origen %>', '<%= ins.referencia %>')" class="p-2 text-orange-600 hover:bg-orange-50 rounded-lg" title="Revisar Pago">
                                      <iconify-icon icon="lucide:dollar-sign" class="text-lg"></iconify-icon>
                                    </button>
                                <% } %>
                              </td>
                            </tr>

                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="p-8 text-center text-gray-500">No hay participantes registrados.</td>
                        </tr>
                    <% } %>

                  </tbody>
                </table>
              </div>
            </div>
        </main>
    </div>

    <div id="modal-edicion" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden flex items-center justify-center z-50">
      <div class="bg-white rounded-xl shadow-xl w-full max-w-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
          <h3 class="text-lg font-bold text-gray-800">Editar Datos del Participante</h3>
          <button onclick="cerrarModal('modal-edicion')" class="text-gray-400 hover:text-gray-600"><iconify-icon icon="lucide:x" class="text-xl"></iconify-icon></button>
        </div>
        <div class="p-6">
          <form id="form-editar-usuario">
            <input type="hidden" id="edit-doc" />
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
                <input type="text" id="edit-nombre" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" value="Carlos">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Apellido</label>
                <input type="text" id="edit-apellido" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" value="Paradas">
              </div>
              <div class="col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
                <input type="text" id="edit-telefono" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-blue-500 focus:border-blue-500" value="+58 4125536625">
              </div>
            </div>
            <div class="mt-6 flex justify-end gap-3">
              <button type="button" onclick="cerrarModal('modal-edicion')" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">Cancelar</button>
              <button type="button" onclick="guardarEdicion()" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700">Guardar Cambios</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div id="modal-pago" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden flex items-center justify-center z-50">
      <div class="bg-white rounded-xl shadow-xl w-full max-w-md overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-orange-50">
          <h3 class="text-lg font-bold text-orange-800">Revisión de Pago</h3>
          <button onclick="cerrarModal('modal-pago')" class="text-gray-400 hover:text-gray-600"><iconify-icon icon="lucide:x" class="text-xl"></iconify-icon></button>
        </div>
        <div class="p-6">
          <div class="bg-gray-50 rounded-lg p-4 mb-6 border border-gray-100">
            <p class="text-sm text-gray-500 mb-1">Titular de la cuenta</p>
            <p class="font-medium text-gray-900 mb-3" id="ver-titular">Maria Mendoza</p>
            <div class="grid grid-cols-2 gap-4">
              <div><p class="text-sm text-gray-500 mb-1">Banco</p><p class="font-medium text-gray-900" id="ver-banco">Banesco</p></div>
              <div><p class="text-sm text-gray-500 mb-1">Referencia</p><p class="font-mono text-gray-900 font-bold tracking-wider" id="ver-referencia">123456</p></div>
            </div>
          </div>
          <div class="flex flex-col gap-3">
            <button type="button" onclick="procesarPago('aprobar')" class="w-full px-4 py-3 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700 flex justify-center items-center gap-2"><iconify-icon icon="lucide:check-circle"></iconify-icon> Aprobar y Conciliar</button>
            <button type="button" onclick="procesarPago('rechazar')" class="w-full px-4 py-3 text-sm font-medium text-red-700 bg-red-50 rounded-lg hover:bg-red-100 border border-red-200 flex justify-center items-center gap-2"><iconify-icon icon="lucide:x-circle"></iconify-icon> Rechazar y Eliminar Reporte</button>
          </div>
        </div>
      </div>
    </div>

    <script>
      // Variable global para guardar qué inscripción estamos revisando
      let inscripcionActiva = null;

      // 1. Funciones para Abrir Modales
      function abrirModalEdicion(cedula, nombre, apellido, telefono) { 
        // Llenamos los inputs ocultos y visibles con los datos actuales
        document.getElementById('edit-doc').value = cedula;
        document.getElementById('edit-nombre').value = nombre;
        document.getElementById('edit-apellido').value = apellido;
        document.getElementById('edit-telefono').value = telefono;
        
        document.getElementById('modal-edicion').classList.remove('hidden'); 
      }
      
      function abrirModalPago(inscodigo, titular, banco, referencia) { 
        // Llenamos los datos visuales en la tarjeta del modal
        document.getElementById('ver-titular').innerText = titular;
        document.getElementById('ver-banco').innerText = banco;
        document.getElementById('ver-referencia').innerText = referencia;
        
        inscripcionActiva = inscodigo; // Guardamos el ID en la memoria
        document.getElementById('modal-pago').classList.remove('hidden'); 
      }
      
      function cerrarModal(id) { 
        document.getElementById(id).classList.add('hidden'); 
      }

      // 2. Funciones de Acción
      async function guardarEdicion() { 
        // Capturamos lo que el administrador escribió
        const doc = document.getElementById('edit-doc').value;
        const nombre = document.getElementById('edit-nombre').value.trim();
        const apellido = document.getElementById('edit-apellido').value.trim();
        const telefono = document.getElementById('edit-telefono').value.trim();

        if(!nombre || !apellido) {
            alert("El nombre y el apellido no pueden estar vacíos.");
            return;
        }

        try {
            // Enviamos los datos al backend
            const response = await fetch('/panel/participantes/editar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ doc, nombre, apellido, telefono })
            });

            const data = await response.json();

            if(data.success) {
                alert("¡Perfil actualizado con éxito!");
                cerrarModal('modal-edicion');
                window.location.reload(); // Recargamos para ver los cambios en la tabla
            } else {
                alert("Error: " + data.message);
            }
        } catch (error) {
            alert("Error de conexión con el servidor.");
        }
      }
      
      function filtrarTabla(estado) {
        // Buscamos todas las filas que tengan la clase 'fila-inscripcion'
        const filas = document.querySelectorAll('.fila-inscripcion');
        
        filas.forEach(fila => {
            // Si el botón seleccionado es 'todas', o si el estado de la fila coincide con el botón...
            if (estado === 'todas' || fila.getAttribute('data-estado') === estado) {
                fila.style.display = ''; // Mostramos la fila
            } else {
                fila.style.display = 'none'; // Ocultamos la fila
            }
        });
      }

      // 3. LA FUNCIÓN ESTRELLA: Procesar Pagos con el Backend
      async function procesarPago(accion) { 
        if(!inscripcionActiva) return;

        let confirmacion = accion === 'aprobar' 
            ? '¿Conciliar pago y notificar al participante?' 
            : '¿Rechazar pago, eliminar reporte y notificar al participante?';

        if(confirm(confirmacion)) {
            try {
                // Hacemos la petición al backend
                const response = await fetch(`/panel/pagos/${accion}/${inscripcionActiva}`, { method: 'POST' });
                const data = await response.json();

                if(data.success) {
                    alert(data.message);
                    window.location.reload(); // Recargamos la página para ver el cambio de color en la tabla
                } else {
                    alert("Error: " + data.message);
                }
            } catch (error) {
                alert("Error de conexión con el servidor.");
            }
        }
        cerrarModal('modal-pago'); 
      }
    </script>
</body>
</html>